{
  "buildCommand": "vite build && esbuild api/index.ts --platform=node --packages=external --bundle --format=esm --outfile=api/handler.js --tsconfig=tsconfig.json",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
